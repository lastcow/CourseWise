# --- Database (Neon Postgres) ---
DATABASE_URL=postgres://user:password@host/dbname

# --- Auth ---
# 32+ byte secret used to sign JWT access tokens (jose). Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string
# Separate 32+ byte secret used to sign JWT refresh tokens (jose).
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ISSUER=coursewise
JWT_AUDIENCE=coursewise-web
# bcrypt cost factor (10-12 recommended on Workers)
BCRYPT_ROUNDS=10

# --- API (Cloudflare Workers) ---
# Set these in .dev.vars for `wrangler dev`
API_BASE_URL=http://localhost:8787
CORS_ORIGIN=http://localhost:5173

# --- Web (Vite) ---
# Prefix with VITE_ to expose to the browser
VITE_API_BASE_URL=http://localhost:8787
VITE_DEFAULT_LOCALE=en

# --- Cloudflare deploy (used by CI; NEVER commit real values) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- AI content generation (Phase 2+) ---
# Cloudflare AI Gateway routes provider calls. Create one in the dashboard and
# paste the account id + gateway slug here. Provider API keys are uploaded as
# Worker secrets and referenced by name from ai_providers.api_key_secret_ref.
AI_GATEWAY_ACCOUNT_ID=
AI_GATEWAY_ID=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
