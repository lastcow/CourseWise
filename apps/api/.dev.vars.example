DATABASE_URL=postgres://user:password@host/dbname
JWT_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ISSUER=coursewise
JWT_AUDIENCE=coursewise-web
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:5173

# R2 / S3-compatible upload pipeline (M2). Generate an R2 API token in the
# Cloudflare dashboard with read+write to coursewise-files.
R2_BUCKET=coursewise-files
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
# Optional. Custom domain for public R2 endpoint; defaults to the *.r2.cloudflarestorage.com host.
R2_PUBLIC_ENDPOINT=

# AI Gateway (Phase 2 content generation). The account id and gateway slug are
# non-secret; ANTHROPIC_API_KEY / OPENAI_API_KEY are provider secrets referenced
# by ai_providers.api_key_secret_ref. AI_GATEWAY_TOKEN is only required when the
# gateway has "Authenticated Gateway" enabled in the Cloudflare dashboard, in
# which case the worker sends `cf-aig-authorization: Bearer <token>`.
AI_GATEWAY_ACCOUNT_ID=
AI_GATEWAY_ID=
AI_GATEWAY_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Gamma Generate API key. Optional in dev — gamma routes return 500 with a
# clear error until this is set. Create one at https://gamma.app/account-settings/api-keys
GAMMA_API_KEY=

# Outbound email uses the Cloudflare Worker `send_email` binding (configured
# in wrangler.toml under [[send_email]]). The binding only exists inside the
# Workers runtime — `wrangler dev` will surface it, but local Node-based
# scripts cannot send. The binding has no API key; bindings are not env vars.
# Optional: override the From: header (defaults to "CourseWise <noreply@fsuac.com>").
EMAIL_FROM=
