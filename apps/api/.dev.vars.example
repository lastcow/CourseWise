DATABASE_URL=postgres://user:password@host/dbname
JWT_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ISSUER=coursewise
JWT_AUDIENCE=coursewise-web
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:5173

# R2 / S3-compatible upload pipeline (M2). Generate an R2 API token in the
# Cloudflare dashboard with read+write to coursewise-files.
R2_BUCKET=coursewise-files
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
# Optional. Custom domain for public R2 endpoint; defaults to the *.r2.cloudflarestorage.com host.
R2_PUBLIC_ENDPOINT=
