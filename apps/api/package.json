{
  "name": "@coursewise/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc -p tsconfig.json --noEmit",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env.local src/db/migrate.ts",
    "db:seed": "tsx --env-file=../../.env.local src/db/seed.ts"
  },
  "dependencies": {
    "@coursewise/shared": "workspace:*",
    "@neondatabase/serverless": "^0.10.1",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.36.0",
    "fflate": "^0.8.2",
    "hono": "^4.6.9",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "wrangler": "^3.84.1"
  }
}
